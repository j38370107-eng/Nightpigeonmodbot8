    "@lezer/highlight": "^1.2.3",
    "@uiw/react-codemirror": "^4.25.10",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-session": "^1.18.1",
    "js-yaml": "^4.2.0",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0"
