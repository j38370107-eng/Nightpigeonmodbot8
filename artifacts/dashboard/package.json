    "@vitejs/plugin-react": "^4.4.1",
    "esbuild": "^0.25.0",
    "lucide-react": "^0.511.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.30.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^6.3.5"
