{
  "name": "@workspace/dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec vite build && node_modules/.bin/tsx server/index.ts",
    "build:client": "pnpm exec vite build",
    "build:server": "node ./build-server.mjs",
